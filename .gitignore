# Local .terraform folder (contains providers and modules)
.terraform/

# Distributed state storage (never commit these)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude sensitive variable files
*.tfvars
*.tfvars.json

# Exclude override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include CLI configuration files
.terraformrc
terraform.rc

# SSH Keys (never commit private keys)
terraform-devops

*.pem

# OS
.DS_Store